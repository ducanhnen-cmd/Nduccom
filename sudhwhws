-- ========== BOSS SYSTEM ==========
local KatakuriNames = {"Katakuri", "Dogtooth", "Charlotte Katakuri", "Katakuri Boss"}
local EliteNames = {"Elite", "Elite Boss", "Boss Elite", "Thunder God", "Elite Hunter"}

local function findKatakuri()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        for _, katName in ipairs(KatakuriNames) do
            if name:find(katName:lower()) and (obj:IsA("Model") or obj:IsA("Part")) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then return {Object = obj, Position = hrp.Position, Humanoid = obj:FindFirstChild("Humanoid"), CFrame = hrp.CFrame} end
            end
        end
    end
    return nil
end

local function findElite()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        for _, eliteName in ipairs(EliteNames) do
            if name:find(eliteName:lower()) and (obj:IsA("Model") or obj:IsA("Part")) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then return {Object = obj, Position = hrp.Position, Humanoid = obj:FindFirstChild("Humanoid"), CFrame = hrp.CFrame} end
            end
        end
    end
    return nil
end

local function scanForBosses()
    local kata = findKatakuri()
    local elite = findElite()
    if kata then print("[Boss] Katakuri at:", kata.Position) end
    if elite then print("[Boss] Elite at:", elite.Position) end
    return kata, elite
end

local function attackBoss(target)
    if not target or not target.Humanoid or target.Humanoid.Health <= 0 then return end
    local remote = ReplicatedStorage:FindFirstChild("Attack") or ReplicatedStorage:FindFirstChild("Damage")
    if remote then remote:FireServer(target.Object) end
end

-- ========== FARM POSITION ==========
local farmRange = 15
local farmPosition = "Above"

local function getDesiredPosition(targetPos, targetCFrame)
    if farmPosition == "Behind" and targetCFrame then
        return targetPos + targetCFrame.LookVector * -farmRange
    elseif farmPosition == "Under" then
        return Vector3.new(targetPos.X, targetPos.Y - farmRange, targetPos.Z)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dir = (targetPos - hrp.Position).Unit
            return targetPos - dir * farmRange
        end
        return targetPos + Vector3.new(farmRange, 0, farmRange)
    end
end

local function moveToTarget(target)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local desired = getDesiredPosition(target.Position, target.CFrame)
    if (hrp.Position - desired).Magnitude > 5 then
        hrp.CFrame = CFrame.new(desired)
        return false
    end
    return true
end

-- ========== FARM BOSS STATE ==========
local isFarmingBoss = false
local currentBossTarget = nil
local bossFarmType = nil
local bossFarmRange = 100
local bossFarmPosition = "Above"

local function getBossDesiredPosition(targetPos, targetCFrame)
    if bossFarmPosition == "Behind" and targetCFrame then
        return targetPos + targetCFrame.LookVector * -bossFarmRange
    elseif bossFarmPosition == "Under" then
        return Vector3.new(targetPos.X, targetPos.Y - bossFarmRange, targetPos.Z)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dir = (targetPos - hrp.Position).Unit
            return targetPos - dir * bossFarmRange
        end
        return targetPos + Vector3.new(bossFarmRange, 0, bossFarmRange)
    end
end

local function moveToBossTarget(target)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local desired = getBossDesiredPosition(target.Position, target.CFrame)
    if (hrp.Position - desired).Magnitude > 5 then
        hrp.CFrame = CFrame.new(desired)
        return false
    end
    return true
end

local function startBossFarming(type)
    if isFarmingBoss then return end
    isFarmingBoss = true
    bossFarmType = type
    print("[Farm Boss] Starting:", type)
    task.spawn(function()
        while isFarmingBoss do
            local target = (bossFarmType == "katakuri") and findKatakuri() or findElite()
            if target then
                currentBossTarget = target
                if moveToBossTarget(target) then
                    attackBoss(target)
                    wait(0.3)
                else
                    wait(0.5)
                end
            else
                wait(5)
            end
        end
    end)
end

local function stopBossFarming()
    isFarmingBoss = false
    currentBossTarget = nil
    print("[Farm Boss] Stopped")
end

-- ========== MAP SCAN FOR TELEPORT ==========
local IslandList = {}
local function scanMap()
    IslandList = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "" and obj.Size.X > 50 and obj.Size.Z > 50 then
            local pos = obj.Position
            local absX, absZ = math.abs(pos.X), math.abs(pos.Z)
            local sea = (absX < 5000 and absZ < 4000) and "Sea 1" or (absX >= 5000 and absX < 10000 and absZ < 5000) and "Sea 2" or (absX >= 10000 or absZ >= 5000) and "Sea 3" or "Unknown"
            table.insert(IslandList, {Name = obj.Name, Position = pos, Sea = sea})
        end
    end
    print("[Map] Found", #IslandList, "islands")
end

