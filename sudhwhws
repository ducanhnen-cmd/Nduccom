local function updateIslandDropdown()
    if #IslandList > 0 then
        islandNames = {}
        islandPosMap = {}
        for _, island in ipairs(IslandList) do
            local name = island.Name .. " [" .. island.Sea .. "]"
            table.insert(islandNames, name)
            islandPosMap[name] = island.Position
        end
    end
end

makeButton(teleRightScroll, "🔄 Scan Map", INFO_COLOR, function()
    scanMap()
    updateIslandDropdown()
end)

makeButton(teleRightScroll, "✨ Teleport to Island", ACCENT, function()
    if selectedIsland and islandPosMap[selectedIsland] then
        teleportTo(islandPosMap[selectedIsland])
    end
end)

