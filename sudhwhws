local function scanServerBosses()
    ServerStatus.Elite = false
    ServerStatus.CakePrince = false
    ServerStatus.MirageIsland = false
    ServerStatus.Katakuri = false
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if name:find("elite") or name:find("elite boss") then ServerStatus.Elite = true end
        if name:find("cake prince") then ServerStatus.CakePrince = true end
        if name:find("mirage") then ServerStatus.MirageIsland = true end
