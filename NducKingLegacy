-- ============ SEA EVENT FARM ============
local seaEventEnabled = false
local selectedSeaEvent = "Ship"
local autoCollectChest = false
local autoRepairShip = false
local seaEventRange = 200

local function getCurrentShip()
    for _, v in pairs(Workspace:GetChildren()) do
        if v:IsA("Model") and v:FindFirstChild("Seat") then
            local seat = v:FindFirstChild("Seat")
            if seat and seat.Occupant and seat.Occupant.Parent == player.Character then
                return v
            end
        end
    end
    return nil
end

local function repairShip()
    local ship = getCurrentShip()
    if ship and ship:FindFirstChild("Health") and ship.Health.Value < ship.MaxHealth.Value then
        local repairRemote = ReplicatedStorage:FindFirstChild("RepairShip")
        if repairRemote then
            repairRemote:FireServer()
        end
    end
end

local function getSeaEventTarget()
    local targets = {}
    local playerPos = character and character:FindFirstChild("HumanoidRootPart")
    if not playerPos then return nil end
    
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") then
            local hrp = v:FindFirstChild("HumanoidRootPart")
            if hrp then
                local distance = (hrp.Position - playerPos.Position).Magnitude
                if distance <= seaEventRange then
                    if selectedSeaEvent == "Ship" and (v.Name:find("EnemyShip") or v.Name:find("MarineShip") or v.Name:find("PirateShip") or v.Name:find("Ship")) then
                        if v:FindFirstChild("Health") and v.Health.Value > 0 then
                            table.insert(targets, {mob = v, distance = distance, type = "Ship"})
                        end
                    end
                    
                    if selectedSeaEvent == "SeaBeast" and (v.Name:find("Kraken") or v.Name:find("SeaKing") or v.Name:find("SeaBeast") or v.Name:lower():find("sea")) then
                        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            table.insert(targets, {mob = v, distance = distance, type = "SeaBeast"})
                        end
                    end
                    
                    if selectedSeaEvent == "Marine" and v.Name:lower():find("marine") and v:FindFirstChild("Humanoid") then
                        if v.Humanoid.Health > 0 then
                            table.insert(targets, {mob = v, distance = distance, type = "Marine"})
                        end
                    end
                    
                    if selectedSeaEvent == "Pirate" and v.Name:lower():find("pirate") and v:FindFirstChild("Humanoid") then
                        if v.Humanoid.Health > 0 then
                            table.insert(targets, {mob = v, distance = distance, type = "Pirate"})
                        end
                    end
                    
                    if autoCollectChest and (v.Name:lower():find("chest") or v.Name:lower():find("barrel")) then
                        table.insert(targets, {mob = v, distance = distance, type = "Chest"})
                    end
                end
            end
        end
    end
    
    if #targets == 0 then return nil end
    table.sort(targets, function(a, b) return a.distance < b.distance end)
    return targets[1]
end

local function attackShipTarget(target)
    if not target then return end
    local targetHrp = target:FindFirstChild("HumanoidRootPart")
    if not targetHrp then return end
    
    local currentTool = character:FindFirstChildWhichIsA("Tool")
    if currentTool then
        local attackRemote = ReplicatedStorage:FindFirstChild("Attack")
        if attackRemote then
            attackRemote:FireServer(currentTool, targetHrp.CFrame)
        end
        
        if autoUseSkills then
            task.spawn(function()
                wait(skillDelay)
                useSkill("Z", target)
                wait(skillDelay)
                useSkill("X", target)
                wait(skillDelay)
                useSkill("C", target)
            end)
        end
    end
end

local function collectChest(chest)
    if chest and chest:FindFirstChild("HumanoidRootPart") then
        local args = {[1] = chest}
        local collectRemote = ReplicatedStorage:FindFirstChild("CollectChest")
        if collectRemote then
            collectRemote:FireServer(unpack(args))
        end
        wait(0.5)
    end
end

local function autoSeaEvent()
    while seaEventEnabled do
        task.wait()
        if character and humanoid and humanoid.Health > 0 then
            if autoRepairShip then
                repairShip()
            end
            
            local target = getSeaEventTarget()
            if target then
                if target.type == "Chest" then
                    collectChest(target.mob)
                    if character:FindFirstChild("HumanoidRootPart") and target.mob:FindFirstChild("HumanoidRootPart") then
                        local tween = TweenService:Create(character.HumanoidRootPart, TweenInfo.new(2), {CFrame = target.mob.HumanoidRootPart.CFrame})
                        tween:Play()
                    end
                else
                    attackShipTarget(target.mob)
                    if character:FindFirstChild("HumanoidRootPart") and target.mob:FindFirstChild("HumanoidRootPart") then
                        local distance = (character.HumanoidRootPart.Position - target.mob.HumanoidRootPart.Position).Magnitude
                        if distance > 30 then
                            local tween = TweenService:Create(character.HumanoidRootPart, TweenInfo.new(distance / 80), {CFrame = target.mob.HumanoidRootPart.CFrame})
                            tween:Play()
                        end
                    end
                end
            else
                wait(1)
            end
        else
            player.CharacterAdded:Wait()
            character = player.Character
            humanoid = character:WaitForChild("Humanoid")
            wait(3)
        end
    end
end

