-- ============ HÀM TẤN CÔNG ============
local function attackMob(mob)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
    
    -- Sử dụng vũ khí hiện tại
    local currentTool = character:FindFirstChildWhichIsA("Tool")
    if currentTool then
        -- Gửi yêu cầu tấn công với vũ khí
        local args = {
            [1] = currentTool,
            [2] = mob.HumanoidRootPart.CFrame
        }
        local attackRemote = ReplicatedStorage:FindFirstChild("Attack")
        if attackRemote then
            attackRemote:FireServer(unpack(args))
        end
        
        -- Tự động dùng skill Z, X, C nếu có
        if autoUseSkills then
            task.spawn(function()
