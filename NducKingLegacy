-- ============ HÀM AUTO FARM CHÍNH (CẬP NHẬT) ============
local function getTargetMob()
    local targets = {}
    local characterPos = character and character:FindFirstChild("HumanoidRootPart")
    if not characterPos then return nil end
    
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            if v.Name ~= player.Name and not v:IsA("Player") then
                local hrp = v:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local distance = (hrp.Position - characterPos.Position).Magnitude
                    if distance <= farmRange then
                        table.insert(targets, {
                            mob = v,
                            distance = distance,
                            hp = v.Humanoid.Health,
                            level = v:FindFirstChild("Level") and v.Level.Value or 0
                        })
                    end
                end
            end
        end
    end
    
    if #targets == 0 then return nil end
    
    if attackMode == "Nearest" then
        table.sort(targets, function(a, b) return a.distance < b.distance end)
    elseif attackMode == "Lowest HP" then
        table.sort(targets, function(a, b) return a.hp < b.hp end)
    elseif attackMode == "Highest Level" then
        table.sort(targets, function(a, b) return a.level > b.level end)
    end
    
    return targets[1].mob
end

local function autoFarm()
    while autoFarmEnabled do
        task.wait()
        if character and humanoid and humanoid.Health > 0 then
            -- Tự động trang bị vũ khí đã chọn
            if selectedWeapon then
                local currentWeapon = getCurrentWeapon()
                if currentWeapon ~= selectedWeapon then
                    equipWeapon(selectedWeapon)
                end
            end
            
            local target = getTargetMob()
            if target then
                attackMob(target)
                if target:FindFirstChild("HumanoidRootPart") and character:FindFirstChild("HumanoidRootPart") then
                    -- Di chuyển đến mục tiêu
                    local hrp = character.HumanoidRootPart
                    local targetPos = target.HumanoidRootPart.Position
                    local distance = (hrp.Position - targetPos).Magnitude
                    
                    if distance > 10 then
                        local tweenInfo = TweenInfo.new(distance / 50, Enum.EasingStyle.Linear)
                        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
                        tween:Play()
                    end
                end
            else
                -- Đợi spawn quái
                wait(1)
            end
        else
            -- Chết thì chờ respawn
            player.CharacterAdded:Wait()
            character = player.Character
            humanoid = character:WaitForChild("Humanoid")
            wait(3)
        end
    end
end

-- Khởi chạy auto farm riêng biệt
